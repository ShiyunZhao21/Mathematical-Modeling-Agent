ENV=dev
# support all model, check out https://docs.litellm.ai/docs/providers
# 智谱 OpenAI 兼容接口推荐：
#   MODEL=openai/glm-4.7
#   BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# docs/md/tutorial
# 为每个 agent 配置合适的模型
COORDINATOR_API_KEY=
COORDINATOR_MODEL=openai/glm-5.1
COORDINATOR_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# COORDINATOR_MAX_TOKENS=

# 推荐 thinking model
MODELER_API_KEY=
MODELER_MODEL=openai/glm-5.1
MODELER_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# MODELER_MAX_TOKENS=

CODER_API_KEY=
CODER_MODEL=openai/glm-5.1
CODER_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# CODER_MAX_TOKENS=

WRITER_API_KEY=
WRITER_MODEL=openai/glm-5.1
WRITER_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# WRITER_MAX_TOKENS=

# 模型最大问答次数
MAX_CHAT_TURNS=70
# 思考反思次数
MAX_RETRIES=5

# 不需要填，默认调用本地 Python
# E2B_API_KEY=
SERVER_HOST=http://127.0.0.1:8000
# 使用 email 注册账号从 https://openalex.org/ 文献
OPENALEX_EMAIL=

LOG_LEVEL=DEBUG
DEBUG=true
# backend-only 版本当前使用本地文件存储任务状态，不依赖 Redis；
# 保留该配置只是为了兼容旧字段。
REDIS_URL=redis://redis:6379/0
# REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
